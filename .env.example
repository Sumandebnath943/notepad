# Copy this file to `.env` and fill in real values. NEVER commit your real .env.

# Prisma / SQLite database location. Relative paths are resolved from the
# project root and work cross-platform.
DATABASE_URL="file:./db/custom.db"

# Secret used to sign session JWTs. MUST be set in production (the app refuses
# to start otherwise) and MUST be long & random — at least 32 characters.
# Generate one with:  openssl rand -base64 48
SESSION_SECRET=""

# Set to 1 ONLY when embedding the app in a cross-origin iframe (e.g. a preview
# sandbox). Leaving it unset keeps clickjacking protection (frame-ancestors
# 'self' + X-Frame-Options: SAMEORIGIN) enabled, which is the secure default.
# ALLOW_IFRAME_EMBED=1
