# Copy this file to `.env.local` (or `.env`) and fill in real values.
# NEVER commit your real env file.

# Supabase project credentials. These are read SERVER-SIDE (Route Handlers +
# middleware); the browser never talks to Supabase directly. The anon key is a
# public value anyway — Row-Level Security, not secrecy of this key, is what
# protects user data. Find them in:
#   Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Set to 1 ONLY when embedding the app in a cross-origin iframe (e.g. a preview
# sandbox). Leaving it unset keeps clickjacking protection (frame-ancestors
# 'self' + X-Frame-Options: SAMEORIGIN) enabled, which is the secure default.
# ALLOW_IFRAME_EMBED=1

# NOTE: Do NOT put your Supabase service_role key here or anywhere client-side.
# This app never needs it — all access goes through the anon key + RLS.
