// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Account for login (login password is separate from the encryption master password).
// Only the bcrypt hash of the LOGIN password is stored here. The master password
// is NEVER stored anywhere — it only exists in memory to derive the Master Key.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    // bcrypt hash of the LOGIN password (NOT the master password)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userKey      UserKey?
  notes        Note[]
}

// Envelope-encryption key material. The DEK (Data Encryption Key) is encrypted
// with the Master Key (derived from the master password via Argon2id). A full
// database breach yields only ciphertext + an Argon2id-encrypted DEK, which is
// useless without the master password.
model UserKey {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kdfSalt      String   // base64 Argon2id salt (unique per user)
  encryptedDek String   // base64 DEK encrypted with Master Key (AES-256-GCM)
  dekNonce     String   // base64 nonce for the DEK encryption
  kdfOpsLimit  Int      // Argon2id ops limit (iterations) used at creation
  kdfMemLimit  Int      // Argon2id memory cost (bytes) used at creation
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Notes are stored as ciphertext only. The combined payload
// JSON.stringify({ title, body }) is encrypted client-side with the DEK
// (AES-256-GCM) using a unique nonce per note. A single AEAD operation over
// the combined payload avoids nonce-reuse pitfalls. The server never sees
// plaintext.
model Note {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ciphertext  String   // base64 ciphertext of JSON({title, body})
  nonce       String   // base64 unique 12-byte nonce per note (AES-256-GCM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, updatedAt])
}
